{
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "**/*.exe",
            "**/*.bat",
            "**/*.sh",
            "**/*.apk",
            "**/*.msi",
            "**/*.dll"
        ],
        "rewrites": [
            {
                "source": "/test-series",
                "destination": "/test-series.html"
            },
            {
                "source": "/prelims",
                "destination": "/prelims.html"
            },
            {
                "source": "/mains",
                "destination": "/mains.html"
            },
            {
                "source": "/notes",
                "destination": "/notes.html"
            },
            {
                "source": "/syllabus",
                "destination": "/syllabus.html"
            }
        ]
    }
}